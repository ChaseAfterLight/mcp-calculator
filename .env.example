# WebSocket endpoint for mcp_pipe.py
MCP_ENDPOINT=ws://127.0.0.1:8080/ws

# SMTP settings for species-card-email-service
SMTP_SERVER=smtp.qq.com
SMTP_PORT=587
EMAIL_FROM=your_email@example.com
SMTP_PASSWORD=your_smtp_app_password

# Gateway settings
MCP_TOOL_TIMEOUT_SEC=25
GATEWAY_MAX_SEARCH_LIMIT=50
GATEWAY_CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Unified startup settings for services/mcp-gateway/run.py
START_MCP_SERVERS=1
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_RELOAD=1
MCP_START_TRANSPORT=http
MCP_HOST=127.0.0.1
MCP_PATH=/mcp
SPECIES_CARD_GENERATOR_PORT=8101
SPECIES_ENCYCLOPEDIA_PORT=8102
SPECIES_CARD_EMAIL_SERVICE_PORT=8103
